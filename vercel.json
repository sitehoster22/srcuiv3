{
  "version": 2,
  "builds": [
    {
      "src": "api/proxy/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/proxy",
      "dest": "/api/proxy/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
